# Container names
TLK_WEB_CONTAINER_NAME=tlk-web
LT_ENGINE_CONTAINER_NAME=lt-engine
LT_PROXY_CONTAINER_NAME=lt-proxy

# TLK web host port
TLK_WEB_HOST_PORT=9070

# Internal engine port (inside Docker network)
LT_ENGINE_INTERNAL_PORT=5000
LT_THREADS=4
LT_LOAD_ONLY=en,pl,de,fr,es,it

# Public host ports (change these to avoid collisions)
LT_HOST_HTTP_PORT=9080
LT_HOST_HTTPS_PORT=9443
